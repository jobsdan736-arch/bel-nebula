# Server
PORT=4000

# Paystack — get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MikroTik router API — leave MIKROTIK_HOST blank to run in mock mode
# while you build/test before the router is wired up.
MIKROTIK_HOST=
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=
MIKROTIK_MOCK=false
